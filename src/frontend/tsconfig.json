// services/vectoplan-editor/src/frontend/tsconfig.json
{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],

    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    "jsx": "preserve",

    "strict": false,
    "alwaysStrict": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "noImplicitOverride": false,
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "useUnknownInCatchVariables": false,
    "forceConsistentCasingInFileNames": true,

    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,

    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@api/*": [
        "./api/*"
      ],
      "@bootstrap/*": [
        "./bootstrap/*"
      ],
      "@camera/*": [
        "./camera/*"
      ],
      "@config/*": [
        "./config/*"
      ],
      "@dom/*": [
        "./dom/*"
      ],
      "@input/*": [
        "./input/*"
      ],
      "@inventory/*": [
        "./inventory/*"
      ],
      "@render/*": [
        "./render/*"
      ],
      "@runtime/*": [
        "./runtime/*"
      ],
      "@scene/*": [
        "./scene/*",
        "./runtime/scene/*"
      ],
      "@runtime-scene/*": [
        "./runtime/scene/*"
      ],
      "@state/*": [
        "./state/*"
      ],
      "@targeting/*": [
        "./targeting/*"
      ],
      "@ui/*": [
        "./ui/*"
      ],
      "@utils/*": [
        "./utils/*"
      ],
      "@world/*": [
        "./runtime/world/*"
      ]
    },

    "types": [
      "vite/client",
      "node"
    ]
  },
  "include": [
    "./main.ts",
    "./vite-env.d.ts",
    "./api/**/*.ts",
    "./bootstrap/**/*.ts",
    "./camera/**/*.ts",
    "./config/**/*.ts",
    "./dom/**/*.ts",
    "./input/**/*.ts",
    "./inventory/**/*.ts",
    "./render/**/*.ts",
    "./runtime/**/*.ts",
    "./scene/**/*.ts",
    "./state/**/*.ts",
    "./targeting/**/*.ts",
    "./ui/**/*.ts",
    "./utils/**/*.ts"
  ],
  "exclude": [
    "./node_modules",
    "./dist",
    "./coverage",
    "./.vite",
    "./.cache",
    "../../static/editor",
    "../../static/editor/**/*",
    "../../../static/editor",
    "../../../static/editor/**/*"
  ]
}
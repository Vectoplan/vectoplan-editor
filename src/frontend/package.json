{
  "//": "services/vectoplan-editor/src/frontend/package.json",
  "name": "@vectoplan/editor-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VECTOPLAN editor frontend runtime connected to vectoplan-chunk through the editor chunk proxy.",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0 --port 5173",
    "clean": "rimraf ../../static/editor ./.vite ./.cache",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "build:only": "vite build --config vite.config.ts",
    "build": "npm run clean && npm run typecheck && npm run build:only && npm run verify:manifest",
    "preview": "vite preview --config vite.config.ts --host 0.0.0.0 --port 4173",
    "verify:manifest": "node ./scripts/verify-manifest.mjs",
    "verify": "npm run typecheck && npm run build:only && npm run verify:manifest"
  },
  "dependencies": {
    "three": "^0.179.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "browserslist": {
    "production": [
      "last 2 Chrome versions",
      "last 2 Edge versions",
      "last 2 Firefox versions",
      "last 2 Safari versions"
    ],
    "development": [
      "last 1 Chrome version",
      "last 1 Edge version",
      "last 1 Firefox version"
    ]
  },
  "vectoplan": {
    "service": "vectoplan-editor",
    "frontendRoot": "services/vectoplan-editor/src/frontend",
    "buildOutputDir": "services/vectoplan-editor/static/editor",
    "editorRoute": "/editor",
    "staticEditorUrlPrefix": "/static/editor",
    "viteEntrypoint": "main.ts",
    "viteManifest": "manifest.json",
    "chunkProxyBaseUrl": "/editor/api/chunk",
    "defaultProjectId": "dev-project",
    "defaultWorldId": "world_spawn",
    "worldSource": "chunk-service",
    "localWorldFallbackEnabled": false,
    "legacyFrontendRootEnabled": false
  }
}